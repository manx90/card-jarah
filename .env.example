
# PostgreSQL — أنشئ قاعدة مسبقاً (مثلاً: createdb jarah)
# مثال محلي:
DATABASE_URL=postgres://jarah:jarah@localhost:5432/jarah
# سحابي غالباً يحتاج: ?sslmode=require
# DATABASE_URL=postgres://user:pass@host:5432/jarah?sslmode=require

# مزامنة مخطط TypeORM — للتطوير الأولي فقط (true) ثم false على الإنتاج
TYPEORM_SYNC=true
AUTH_SECRET=mansiyah

# مدير افتراضي — يُنشأ تلقائياً عند بدء الخادم إن لم يكن موجوداً
ADMIN_EMAIL=mo.mansiyah@gmail.com
ADMIN_PASSWORD=mansiyah

# CBK Hosted (KNET / T-Pay) — أسرار الخادم فقط (لا تُعرَّف على العميل)
# اختبار البنك: https://pgtest.cbk.com (انظر Test Code Sample/)
CBK_PG_BASE_URL=https://pgtest.cbk.com
CBK_CLIENT_ID=
CBK_CLIENT_SECRET=
CBK_ENCRP_KEY=
# POST /api/v1/purchases/checkout — عودة المستخدم GET /api/v1/payments/cbk/return
APP_URL=http://localhost:3000
# أو NEXT_PUBLIC_APP_URL لنفس القيمة
CBK_CURRENCY=KWD
CBK_PAYMENT_LANG=ar
# اختياري: 1=KNET 2=T-Pay QR — فارغ = صفحة اختيار البوابة
# CBK_PAY_TYPE=
