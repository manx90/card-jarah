
# PostgreSQL — أنشئ قاعدة مسبقاً (مثلاً: createdb jarah)
# مثال محلي:
DATABASE_URL=postgres://jarah:jarah@localhost:5432/jarah
# سحابي غالباً يحتاج: ?sslmode=require
# DATABASE_URL=postgres://user:pass@host:5432/jarah?sslmode=require

# مزامنة مخطط TypeORM — للتطوير الأولي فقط (true) ثم false على الإنتاج
TYPEORM_SYNC=true
AUTH_SECRET=mansiyah
# عنوان التطبيق — محلي:
AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
# إنتاج (VPS + نطاق farha.live) — على السيرفر فقط، مع https بعد SSL:
# AUTH_URL=https://farha.live
# APP_URL=https://farha.live

# مدير افتراضي — يُنشأ تلقائياً عند بدء الخادم إن لم يكن موجوداً
ADMIN_EMAIL=mo.mansiyah@gmail.com
ADMIN_PASSWORD=mansiyah
ADMIN_NAME=mansiyah

# CBK Hosted (KNET / T-Pay) — أسرار الخادم فقط (لا تُعرَّف على العميل)
# اختبار البنك: https://pgtest.cbk.com (انظر Test Code Sample/)
CBK_PG_BASE_URL=https://pgtest.cbk.com
# أو CBK_BASE_URL (نفس القيمة — كما في payment-gateway)
CBK_CLIENT_ID=
CBK_CLIENT_SECRET=
CBK_ENCRP_KEY=
# عودة CBK — اختياري إن وُجد APP_URL
# CBK_RETURN_URL=https://farha.live/api/v1/payments/cbk/return
CBK_REQUEST_TIMEOUT=30000
CBK_CURRENCY=KWD
CBK_PAYMENT_LANG=ar
# اختياري: 1=KNET 2=T-Pay QR — فارغ = صفحة اختيار البوابة
# CBK_PAY_TYPE=

# سجلات JSON في مجلد logs/ (يومياً: *-access.log *-error.log *-event.log *-auth.log *-payment-error.log *-payment-provider.log)
# LOG_DIR=./logs
# LOG_TO_FILE=false
