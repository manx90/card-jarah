
# SQLite — مسار ملف القاعدة (يُنشأ المجلد تلقائياً إن لزم)
DATABASE_URL=file:./data/jarah.sqlite
# مزامنة مخطط TypeORM — للتطوير الأولي فقط (true) ثم false على الإنتاج
TYPEORM_SYNC=true
AUTH_SECRET=mansiyah

# (اختياري) بريد وكلمة مرور أدمن عند أول اتصال بقاعدة البيانات
# إن لم تُضبط، يُستخدم الافتراضي من src/lib/admin-defaults.ts
# BOOTSTRAP_ADMIN_EMAIL=admin@jarah.local
# BOOTSTRAP_ADMIN_PASSWORD=Jarah_Admin_2026
